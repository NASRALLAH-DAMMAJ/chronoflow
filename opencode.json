{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp", "--headless", "--browser", "chromium", "--no-sandbox", "--caps", "vision", "--allowed-hosts", "localhost,127.0.0.1"],
      "enabled": true,
      "env": {}
    }
  },
  "provider": {
    "Qwen": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Qwen (DashScope Intl)",
      "options": {
        "baseURL": "https://dashscope-intl.aliyuncs.com/compatible-mode/v1"
      },
      "models": {
        "qwen3.7-plus": {
          "name": "Qwen3.7 plus"
        }
      }
    }
  },
  "model": "qwen/qwen3.7-plus"
}
